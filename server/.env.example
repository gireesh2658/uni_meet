# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration
MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster_url>/unimeet?retryWrites=true&w=majority

# JWT Secrets & Expiry
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# Email Transporter (Go to Google Account -> Security -> App Passwords)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_digit_app_password
EMAIL_FROM=Unimeet System <your_email@gmail.com>

# Security
BCRYPT_SALT_ROUNDS=12
ADMIN_SECRET=your_admin_secret_key

# Frontend Client URL (For CORS and email links)
CLIENT_URL=http://localhost:8080
